pkgname = linux-ltbv3
	pkgdesc = The Linux built with the LLVM toolchain, ThinLTO, BORE CPU Scheduling, BOLT, and x86-64-v3 CPU optimizations kernel and modules
	depends = coreutils
	depends = initramfs
	depends = kmod
	optdepends = linux-firmware: firmware images needed for some devices
	optdepends = scx-scheds: to use sched-ext schedulers
	optdepends = wireless-regdb: to set the correct wireless channels of your country
	provides = KSMBD-MODULE
	provides = VIRTUALBOX-GUEST-MODULES
	provides = WIREGUARD-MODULE
	replaces = virtualbox-guest-modules-arch
	replaces = wireguard-arch

pkgname = linux-ltbv3-headers
	pkgdesc = Headers and scripts for building modules for the Linux built with the LLVM toolchain, ThinLTO, BORE CPU Scheduling, BOLT, and x86-64-v3 CPU optimizations kernel
	depends = pahole
