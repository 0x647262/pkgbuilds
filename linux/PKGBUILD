pkgbase=linux-ltbv3
pkgver=6.11.8.arch1
pkgrel=2
pkgdesc='Linux built with the LLVM toolchain, ThinLTO, BORE CPU Scheduling, BOLT, and x86-64-v3 CPU optimizations'
_srctag=v${pkgver%.*}-${pkgver##*.}
url='https://github.com/archlinux/linux'
arch=(x86_64)
license=(GPL-2.0-only)
makedepends=(
  bc
  cpio
  gettext
  libelf
  pahole
  perl
  python
  tar
  xz
  clang
  lld
  llvm
)
options=(
  !debug
  !strip
)
_srcname=linux-${pkgver%.*}
_srctag=v${pkgver%.*}-${pkgver##*.}
source=(
  https://cdn.kernel.org/pub/linux/kernel/v"${pkgver%%.*}.x/$_srcname".tar.{xz,sign}
  "$url/releases/download/$_srctag/linux-$_srctag".patch.zst{,.sig}
  config # the main kernel config file
  https://raw.githubusercontent.com/firelzrd/bore-scheduler/refs/heads/main/patches/stable/linux-6.11-bore/0001-linux6.11.y-bore5.7.3.patch
)
validpgpkeys=(
