-
-    _pick vkfdreno $libdir/libvulkan_freedreno.so
-
-    _pick vkgfxstr $libdir/libvulkan_gfxstream.so
-
-    _pick vkintel $libdir/libvulkan_intel{,_hasvk}.so
-
-    _pick vkkosmic $libdir/libvulkan_kosmickrisp.so
