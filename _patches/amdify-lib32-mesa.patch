-
-    _pick vkpfrost $libdir/libvulkan_panfrost.so
-
-    _pick vkpowrvr $libdir/libvulkan_powervr_mesa.so
-
     _pick vkradeon $libdir/libvulkan_radeon.so
 
     _pick vkswrast $libdir/libvulkan_lvp.so
